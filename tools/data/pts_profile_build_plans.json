{
  "DIS": {
    "profile": "DIS",
    "objective_he": "מינימום builds כדי לאפשר הרצה ידנית של כלל קבוצות הטסטים ב-PTS לפרופיל DIS",
    "minimum_build_count": 1,
    "minimum_metric": "minimal_build_variants",
    "source_policy": "Bluetooth SIG + Zephyr official only",
    "manual_pts_only": true,
    "generic_command_templates": {
      "build": "west build -b <BOARD> <SAMPLE_PATH> -d <BUILD_DIR> [-- -D... ]",
      "flash": "west flash -d <BUILD_DIR> [--dev-id <SERIAL>]"
    },
    "example_board_presets": [
      {
        "id": "ti_r53",
        "label": "TI CC2340R53 LaunchPad",
        "board": "lp_em_cc2340r53/cc2340r53"
      }
    ],
    "builds": [
      {
        "id": "dis_base",
        "title_he": "DIS בסיסי מלא (manual PTS)",
        "sample_path": "zephyr/samples/bluetooth/peripheral_dis",
        "build_dir": "build_pts_dis_base",
        "build_kind": "sample_default",
        "why_needed_he": "Build בסיסי ממוקד DIS עם sample ייעודי של Zephyr לבדיקות PTS ידניות.",
        "config_strategy_he": "שימוש ב-prj.conf של sample כבסיס, ללא overlay נוסף בגרסה הראשונה.",
        "config_changes": [
          {
            "type": "sample_default",
            "path": "zephyr/samples/bluetooth/peripheral_dis/prj.conf",
            "note_he": "נקודת בסיס רשמית של Zephyr עבור DIS"
          }
        ],
        "commands": {
          "generic": {
            "build": "west build -b <BOARD> zephyr/samples/bluetooth/peripheral_dis -d build_pts_dis_base",
            "flash": "west flash -d build_pts_dis_base --dev-id <SERIAL>"
          },
          "examples": [
            {
              "preset_id": "ti_r53",
              "build": "west build -b lp_em_cc2340r53/cc2340r53 zephyr/samples/bluetooth/peripheral_dis -d build_pts_dis_base",
              "flash": "west flash -d build_pts_dis_base --dev-id <SERIAL>"
            }
          ]
        },
        "coverage": {
          "mode": "all_profile_tcids"
        },
        "coverage_display": {
          "groups_he": [
            "כל טסטי DIS לפי TCRL (בכפוף ל-ICS/IXIT שתוגדר ב-PTS וליכולות sample זה)"
          ]
        },
        "limitations_he": [
          "לא מבטיח Pass/Fail בפועל; מציג build בסיסי להרצה ידנית ב-PTS.",
          "טסטים שתלויים באפשרויות DIS אופציונליות מעבר לקונפיגורציה הנוכחית עשויים לדרוש variant נוסף."
        ],
        "sources": [
          {
            "file": "docs/profiles/DIS/Test_Suite_TS.pdf",
            "note": "TS רשמי"
          },
          {
            "file": "docs/profiles/DIS/Test_Case_Reference_List_TCRL",
            "note": "TCRL רשמי"
          },
          {
            "file": "docs/profiles/DIS/Implementation_Conformance_Statement_ICS.pdf",
            "note": "ICS רשמי"
          },
          {
            "file": "zephyr/samples/bluetooth/peripheral_dis/README.rst",
            "note": "Sample רשמי של Zephyr"
          },
          {
            "file": "zephyr/samples/bluetooth/peripheral_dis/prj.conf",
            "note": "קונפיגורציה בסיסית"
          }
        ]
      }
    ]
  },
